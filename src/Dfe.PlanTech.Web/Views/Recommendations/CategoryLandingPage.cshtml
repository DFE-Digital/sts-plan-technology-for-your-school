@using Dfe.PlanTech.Application.Providers.Interfaces
@inject IMicrocopyProvider Microcopy
@model CategoryLandingPageViewModel

@{

    var dynamicValues = new Dictionary<string, string>
    {
        ["standard"] = Model.Category.Header.Text.ToLower()
    };
    var printLinkText = await Microcopy.GetTextByKeyAsync(
        ContentfulMicrocopyConstants.LandingPagePrintLink,
        dynamicValues
    );
}

@section NavButton {
    <govuk-back-link id="category-back-link" href="@UrlConstants.HomePage" class="noprint js-only">
        @await Microcopy.GetTextByKeyAsync(ContentfulMicrocopyConstants.LandingPageBackLink)
    </govuk-back-link>
}

@section RelatedActions {
    <hr class="govuk-section-break govuk-section-break--visible govuk-section-break govuk-section-break--visible custom-hr-blue">
    <h2 class="govuk-heading-m govuk-!-padding-top-4">Related actions</h2>

    <p class="govuk-body-s">
        <a class="govuk-link" href="@Model.Slug/share">Share this list of recommendations</a>
    </p>
    <p class="govuk-body-s">
        <a class="govuk-link" href="@Model.Slug/print">@printLinkText</a>
    </p>
}

@foreach (var content in Model.BeforeTitleContent)
{
    await Html.RenderPartialAsync("Components/PageComponentFactory", content);
}

@await Component.InvokeAsync("CategoryLanding", new {
    category = Model.Category,
    slug = Model.Slug,
    sectionName = Model.SectionName,
    sortOrder = Model.SortOrder,
})

@section AfterContent {
    @foreach (var content in Model.AfterContentContent)
    {
        if (Model.HasBanner && content.GetType() == typeof(ComponentBannerEntry))
        {
            await Html.RenderPartialAsync("Banner", content);
        }
        else
        {
            await Html.RenderPartialAsync("Components/PageComponentFactory", content);
        }
        
    }
}
