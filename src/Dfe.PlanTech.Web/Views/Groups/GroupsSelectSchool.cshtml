@using Dfe.PlanTech.Application.Providers.Interfaces
@inject IMicrocopyProvider Microcopy
@model GroupsSelectorViewModel

@{
    ViewData[StatePassingMechanismConstants.Title] = "Select a school";
}

@foreach (var content in Model.BeforeTitleContent)
{
    await Html.RenderPartialAsync("Components/PageComponentFactory", content);
}

<partial name="Components/PageComponentFactory" model="@Model.Title" />

@if (Model.Content != null)
{
    foreach (var content in Model.Content)
    {
        <partial name="Components/PageComponentFactory" model="content" />
    }
}

@{
    var schoolNameGroups = Model.GroupEstablishments.GroupBy(ge => ge.EstablishmentName);
    var hasMultipleSchoolsWithSameName = schoolNameGroups.Any(group => group.Count() > 1);

    <h2 class="govuk-heading-l">@await Microcopy.GetTextByKeyAsync(ContentfulMicrocopyConstants.GroupsSelectHeader)</h2>

    foreach (var school in @Model.GroupEstablishments)
    {
        var schoolUrn = school.Urn;
        var schoolName = school.EstablishmentName;
        var dynamicValues = new Dictionary<string, string>
        {
            ["count"] = school.InProgressOrCompletedRecommendationsCount.ToString(),
            ["total"] = Model.TotalRecommendations,
        };

        <form asp-action="SelectSchool" method="post">
            @{
                var hasUrn = !string.IsNullOrWhiteSpace(school.Urn);
                var linkClass = hasUrn ? "govuk-!-margin-bottom-0" : "";
            }

            <button type="submit" class="govuk-button school-button govuk-!-text-align-left @linkClass" value="@schoolUrn">@schoolName</button>
            @if(hasUrn && hasMultipleSchoolsWithSameName)
            {
                <p class="govuk-caption-m govuk-!-margin-top-0 govuk-!-margin-bottom-2">URN: @school.Urn</p>
            }
            <input type="hidden" name="schoolUrn" value="@schoolUrn" />
            <input type="hidden" name="schoolName" value="@schoolName" />
            <p>@await Microcopy.GetTextByKeyAsync(ContentfulMicrocopyConstants.GroupsSelectRecommendationCount, dynamicValues)</p>
        </form>
    }
}
@{
    var contactLink = new Dictionary<string, string>
    {
        ["contactLink"] = $"<a href=\"{Model.ContactLinkHref}\" target=\"_blank\" class=\"govuk-link\">Contact us (opens in new tab)</a>"
    };
}

<hr class="govuk-section-break govuk-section-break--m" />
<p class="govuk-body">@Html.Raw(await Microcopy.GetTextByKeyAsync(ContentfulMicrocopyConstants.GroupsSelectContactUs, contactLink))</p>
