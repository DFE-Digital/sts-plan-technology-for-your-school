@inject GoogleTagManagerConfiguration GtmConfiguration;
@inject ICookieService CookieService;

@if(!CookieService.Cookie.UseCookies){
  return;
}

<noscript>
    <iframe title="google-tag-manager" src="https://www.googletagmanager.com/ns.html?id=@GtmConfiguration.Id" height="0" width="0" style="display:none;visibility:hidden"></iframe>
</noscript>
