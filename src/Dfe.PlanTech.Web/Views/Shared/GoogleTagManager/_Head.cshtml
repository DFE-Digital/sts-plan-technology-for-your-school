@inject GoogleTagManagerConfiguration GtmConfiguration;
@inject ICookieService CookieService;
@inject ICurrentUser CurrentUser

@if (!CookieService.Cookie.UseCookies)
{
    // No consent: bail (or init Consent Mode here if you use it)
    return;
}

@{
    var isAuthenticated = CurrentUser.IsAuthenticated;
    object? dataLayerObj = null;

    if (isAuthenticated)
    {
        var establishmentId = (await CurrentUser.GetActiveEstablishmentIdAsync())?.ToString() ?? "Unknown";
        var establishmentType = CurrentUser.UserOrganisationTypeName ?? (CurrentUser.UserOrganisationCategoryName ?? "Unknown");

        dataLayerObj = new
        {
            establishment_id = establishmentId,
            establishment_type = establishmentType,
            event_name = "establishmentTypeEvent"
        };
    }

    var jsonOptions = new JsonSerializerOptions
    {
        DefaultIgnoreCondition = JsonIgnoreCondition.WhenWritingNull
    };
    var dataLayerJson = dataLayerObj is null ? "" : JsonSerializer.Serialize(dataLayerObj, jsonOptions);
    var nonce = Context.Items["nonce"]?.ToString();
}

@if (!string.IsNullOrEmpty(GtmConfiguration.SiteVerificationId))
{
    <meta name="google-site-verification" content="@GtmConfiguration.SiteVerificationId" />
}

<!-- Google Tag Manager -->
<script nonce="@nonce">
    (function (w, d, s, l, i) {
        w[l] = w[l] || [];

        if (@isAuthenticated.ToString().ToLower()) {
            // Push server-derived context first
            w[l].push(@Html.Raw(dataLayerJson));
        }

        // Then the GTM boot event
        w[l].push({
            'gtm.start': new Date().getTime(),
            'event': 'gtm.js'
        });

        var f = d.getElementsByTagName(s)[0],
            j = d.createElement(s),
            dl = l != 'dataLayer' ? '&l=' + l : '';

        // Carry CSP nonce to external script
        var n = d.querySelector('[nonce]');
        if (n) { j.setAttribute('nonce', n.nonce || n.getAttribute('nonce')); }

        j.async = true;
        j.src = 'https://www.googletagmanager.com/gtm.js?id=' + i + dl;
        f.parentNode.insertBefore(j, f);
    })
    (window, document, 'script', 'dataLayer', '@GtmConfiguration.Id');
</script>
<!-- End Google Tag Manager -->
