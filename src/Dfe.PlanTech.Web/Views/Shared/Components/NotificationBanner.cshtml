@inject IBannerConditionsContextProvider BannerContext
@model ComponentNotificationBannerEntry

@{

    var shouldShowBanner = await BannerContext.RecordViewActionAndGetBannerVisibility(Model);
    if (shouldShowBanner)
    {
        <govuk-notification-banner>
        @{
            await Html.RenderPartialAsync("Components/PageComponentFactory", Model.Text);
        }
        </govuk-notification-banner>
    }
}
